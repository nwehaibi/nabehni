        u = query.from_user
        ensure_user(u.id, u.first_name, u.username or "")

        # إلغاء
        if data == "cancel_action":
            user_states.pop(u.id, None)
            await query.edit_message_text("✅ تم الإلغاء.")
            return

        # القائمة
        if data == "back_to_menu":
            user_states.pop(u.id, None)
            await query.edit_message_text(
                "👋 أهلاً فيك في *نبّهني*!\n\n"
                "🔔 نتابع لك أسعار المنتجات وننبّهك أول ما ينزل السعر.\n\n"
                "اختر الباقة:",
                parse_mode="Markdown",
                reply_markup=build_main_menu_keyboard(),
            )
            return

        # المجانية
        if data == "plan_free":
            user_data = get_user(u.id)
            if user_data and user_data.get("used_free_trial"):
                await query.edit_message_text(
                    "⚠️ سبق لك استخدام التجربة المجانية.\n\nاختر باقة مدفوعة:",
                    reply_markup=build_upgrade_keyboard(),
                )
                return
            msg = activate_plan(u.id, "free")
            await query.edit_message_text(msg, parse_mode="Markdown")
            return

        # المدفوعة
        if data in ("plan_basic", "plan_pro"):
            plan_key = data.replace("plan_", "")
            plan = PLANS[plan_key]
            await query.edit_message_text(
                f"{plan['description']}\n{'─' * 25}\n\n"
                f"1️⃣ اضغط الزر أدناه للدفع\n"
                f"2️⃣ بعد الدفع اضغط \"✅ دفعت\" وأرسل رقم الطلب",
                parse_mode="Markdown",
                reply_markup=build_paid_plan_keyboard(plan_key),
            )
            return

        # تأكيد الدفع
        if data.startswith("paid_"):
            plan_key = data.replace("paid_", "")
            user_states[u.id] = {"state": "waiting_order", "plan_key": plan_key}
            await query.edit_message_text(
                "📝 أرسل رقم الطلب من سلة:\n\n_(تلقاه في إيميل تأكيد الطلب)_",
                parse_mode="Markdown",
                reply_markup={"inline_keyboard": [[{"text": "⬅️ رجوع", "callback_data": f"plan_{plan_key}"}]]},
            )
            return

        # حذف منتج
        if data.startswith("del_"):
            pid = int(data.replace("del_", ""))
            conn = get_db()
            prod = conn.execute("SELECT title FROM products WHERE id = ? AND user_id = ?", (pid, u.id)).fetchone()
            conn.close()

            if prod:
                delete_product(pid)
                remaining = len(get_user_products(u.id))
                user_data = get_user(u.id)
                max_p = user_data["max_products"] if user_data else 1

                await query.edit_message_text(
                    f"🗑 تم حذف: *{prod['title'][:45]}*\n\n"
                    f"📦 المتبقية: {remaining}/{max_p}\n\n"
                    f"أرسل رابط منتج جديد لإضافته 🔗",
                    parse_mode="Markdown",
                )
            else:
                await query.edit_message_text("⚠️ المنتج غير موجود.")
            return

        # تفعيل الأدمن
        if data.startswith("adm_ok_"):
            if u.id != ADMIN_ID:
                return
            parts = data.replace("adm_ok_", "").split("_")
            plan_key = parts[0]
            target_uid = int(parts[1])
            ensure_user(target_uid)
            msg = activate_plan(target_uid, plan_key)
            await query.edit_message_text(
                f"✅ تم تفعيل {PLANS[plan_key]['name_short']} لـ `{target_uid}`",
                parse_mode="Markdown",
            )
            try:
                await context.bot.send_message(chat_id=target_uid, text=msg, parse_mode="Markdown")
            except Exception:
                pass
            return

        # رفض الأدمن
        if data.startswith("adm_no_"):
            if u.id != ADMIN_ID:
                return
            target_uid = int(data.replace("adm_no_", ""))
            await query.edit_message_text(f"❌ تم رفض طلب `{target_uid}`", parse_mode="Markdown")
            try:
                await context.bot.send_message(
                    chat_id=target_uid,
                    text="❌ لم نتمكن من التحقق من الدفع.\nتأكد من رقم الطلب عبر /report",
                )
            except Exception:
                pass
            return

        # رد الأدمن على بلاغ
        if data.startswith("reply_"):
            if u.id != ADMIN_ID:
                return
            target_uid = int(data.replace("reply_", ""))
            user_states[u.id] = {"state": "waiting_admin_reply", "target_uid": target_uid}
            await query.edit_message_text(
                f"💬 اكتب ردك على المستخدم `{target_uid}` وأرسله:",
                parse_mode="Markdown",
            )
            return

        # خيارات التنبيه
        if data == "alert_any":
            state = user_states.get(u.id, {})
            if state.get("state") == "choosing_alert":
                user_data = get_user(u.id)
                products = get_user_products(u.id)
                max_p = user_data["max_products"] if user_data else 1

                if len(products) >= max_p:
                    await query.edit_message_text(
                        f"⚠️ وصلت الحد ({max_p} منتج).\nترقّي باقتك /start"
                    )
                    user_states.pop(u.id, None)
                    return

                pid = add_product(u.id, state["url"], state["product_info"], None)
                user_states.pop(u.id, None)

                info = state["product_info"]
                cur = info.get("currency", "ر.س")
                await query.edit_message_text(
                    f"✅ تمت إضافة المنتج!\n\n"
                    f"📦 {info['title'][:60]}\n"
                    f"💰 السعر: {info['price']} {cur}\n"
                    f"🔔 تنبيه: لما ينزل أي مبلغ\n"
                    f"🏪 {info['store']}\n\n"
                    f"📊 المنتجات: {len(products)+1}/{max_p}",
                    parse_mode="Markdown",
                )
            return

        if data == "alert_target":
            state = user_states.get(u.id, {})
            if state.get("state") == "choosing_alert":
                user_states[u.id]["state"] = "waiting_target_price"
                cur = state["product_info"].get("currency", "ر.س")
                await query.edit_message_text(
                    f"💰 السعر الحالي: {state['product_info']['price']} {cur}\n\n"
                    "🎯 أرسل السعر المستهدف:"
                )
            return

        # تحقق من دعم المتجر
        if data == "check_store":
            user_states[u.id] = {"state": "waiting_check_store"}
            await query.edit_message_text(
                "🔍 *تحقق من دعم المتجر*\n\n"
                "أرسل رابط أي منتج من المتجر وراح نتحقق لك إذا نقدر نتابع أسعاره.",
                parse_mode="Markdown",
                reply_markup={"inline_keyboard": [[{"text": "⬅️ رجوع", "callback_data": "back_to_menu"}]]},
            )
            return

        # طلب دعم متجر جديد
        if data == "request_store_support":
            # نستخرج اسم المتجر والرابط من نص الرسالة (أضمن من user_states)
            msg_text = query.message.text or ""
            store_name = "غير محدد"
            store_url = "غير محدد"
            for line in msg_text.split("\n"):
                if line.strip().startswith("🏪"):
                    store_name = line.replace("🏪", "").strip()
                elif line.strip().startswith("🔗"):
                    store_url = line.replace("🔗", "").strip()
            user_states.pop(u.id, None)
            await context.bot.send_message(
                chat_id=ADMIN_ID,
                text=(
                    f"📩 *طلب دعم متجر جديد*\n\n"
                    f"👤 {u.first_name} (`{u.id}`)\n"
                    f"🏪 المتجر: {store_name}\n"
                    f"🔗 الرابط: {store_url}\n"
                    f"🕐 {datetime.now().strftime('%Y/%m/%d %H:%M')}"
                ),
                parse_mode="Markdown",
                reply_markup={"inline_keyboard": [
                    [{"text": "✅ تم إضافة دعم المتجر", "callback_data": f"store_added_{u.id}"}],
                ]},
            )
            await query.edit_message_text(
                "✅ تم إرسال طلبك!\n\n"
                "راح نضيف دعم المتجر في أقرب وقت ونبلّغك. شكرًا لك! 🙏"
            )
            return

        # تأكيد الأدمن إضافة دعم متجر
        if data.startswith("store_added_"):
            if u.id != ADMIN_ID:
                return
            target_uid = int(data.replace("store_added_", ""))
            await query.edit_message_text(
                query.message.text + "\n\n✅ تم إضافة الدعم وتم إبلاغ العميل.",
                parse_mode="Markdown",
            )
            try:
                await context.bot.send_message(
                    chat_id=target_uid,
                    text="🎉 *خبر سار!*\n\nالمتجر اللي طلبت دعمه أصبح مدعوم الآن!\nجرّب أرسل رابط المنتج وتابع سعره. 🚀",
                    parse_mode="Markdown",
                )
            except Exception:
                pass
            return

    # ─── الرسائل ──────────────────────────────────────
    async def handle_message(update: Update, context):
        u = update.effective_user
        text = update.message.text.strip()
        ensure_user(u.id, u.first_name, u.username or "")

        state = user_states.get(u.id, {})
        current_state = state.get("state", "")

        # ── رد الأدمن على عميل ──
        if current_state == "waiting_admin_reply" and u.id == ADMIN_ID:
            target_uid = state["target_uid"]
            user_states.pop(u.id, None)
            try:
                await context.bot.send_message(
                    chat_id=target_uid,
                    text=f"💬 *رد من فريق نبّهني:*\n\n{text}",
                    parse_mode="Markdown",
                )
                await update.message.reply_text(f"✅ تم إرسال الرد لـ `{target_uid}`", parse_mode="Markdown")
            except Exception as e:
                await update.message.reply_text(f"❌ فشل الإرسال: {e}")
            return

        # ── رقم الطلب ──
        if current_state == "waiting_order":
            plan_key = state.get("plan_key", "basic")
            plan = PLANS[plan_key]
            save_order(u.id, plan_key, text)
            user_states.pop(u.id, None)

            await update.message.reply_text(
                f"✅ تم استلام رقم الطلب: *{text}*\n\n"
                f"الباقة: {plan['name']}\n\n⏳ جاري التحقق... 🚀",
                parse_mode="Markdown",
            )

            await context.bot.send_message(
                chat_id=ADMIN_ID,
                text=(
                    f"🔔 *طلب جديد!*\n\n"
                    f"👤 {u.first_name} (`{u.id}`)\n"
                    f"📦 {plan['name']}\n"
                    f"🧾 رقم الطلب: `{text}`\n"
                    f"🕐 {datetime.now().strftime('%Y/%m/%d %H:%M')}"
                ),
                parse_mode="Markdown",
                reply_markup={"inline_keyboard": [
                    [{"text": f"✅ فعّل {plan['name_short']}", "callback_data": f"adm_ok_{plan_key}_{u.id}"}],
                    [{"text": "❌ رفض", "callback_data": f"adm_no_{u.id}"}],
                ]},
            )
            return

        # ── البلاغ ──
        if current_state == "waiting_report":
            user_states.pop(u.id, None)
            save_report(u.id, text)
            await context.bot.send_message(
                chat_id=ADMIN_ID,
                text=f"📬 *بلاغ جديد*\n\n👤 {u.first_name} (`{u.id}`)\n💬 {text}",
                parse_mode="Markdown",
                reply_markup={"inline_keyboard": [
                    [{"text": "💬 رد على العميل", "callback_data": f"reply_{u.id}"}]
                ]},
            )
            await update.message.reply_text("✅ تم إرسال بلاغك. شكرًا!")
            return

        # ── السعر المستهدف ──
        if current_state == "waiting_target_price":
            try:
                target = float(text.replace(",", "").replace("٫", "."))
            except ValueError:
                await update.message.reply_text("⚠️ أرسل رقم صحيح.")
                return

            user_data = get_user(u.id)
            products = get_user_products(u.id)
            max_p = user_data["max_products"] if user_data else 1

            if len(products) >= max_p:
                await update.message.reply_text(f"⚠️ وصلت الحد ({max_p} منتج). ترقّي /start")
                user_states.pop(u.id, None)
                return

            info = state["product_info"]
            add_product(u.id, state["url"], info, target)
            user_states.pop(u.id, None)

            cur = info.get("currency", "ر.س")
            await update.message.reply_text(
                f"✅ تمت إضافة المنتج!\n\n"
                f"📦 {info['title'][:60]}\n"
                f"💰 السعر: {info['price']} {cur}\n"
                f"🎯 تنبيه عند: {target} {cur}\n"
                f"🏪 {info['store']}\n\n"
                f"📊 المنتجات: {len(products)+1}/{max_p}",
                parse_mode="Markdown",
            )
            return

        # ── تحقق من دعم المتجر ──
        if current_state == "waiting_check_store":
            check_url = re.search(r"https?://\S+", text)
            if not check_url:
                await update.message.reply_text("⚠️ أرسل رابط منتج صحيح يبدأ بـ https://")
                return

            check_url = check_url.group()
            store_name = detect_store_name(check_url)
            await update.message.reply_text(f"🔍 جاري التحقق من {store_name}...")

            product_info = await fetch_price(check_url)
            user_states.pop(u.id, None)

            if product_info:
                cur = product_info.get("currency", "ر.س")
                await update.message.reply_text(
                    f"✅ *المتجر مدعوم!*\n\n"
                    f"🏪 {product_info['store']}\n"
                    f"📦 {product_info['title'][:60]}\n"
                    f"💰 السعر: {product_info['price']} {cur}\n\n"
                    f"نقدر نتابع أسعار منتجاته. اختر باقة وأرسل الرابط! 🚀",
                    parse_mode="Markdown",
                    reply_markup=build_main_menu_keyboard(),
                )
            else:
                await update.message.reply_text(
                    f"❌ *المتجر غير مدعوم حالياً*\n\n"
                    f"🏪 {store_name}\n"
                    f"🔗 {check_url}\n\n"
                    f"ما قدرنا نجلب السعر من هالمتجر.\n"
                    f"تقدر تطلب إضافة دعم المتجر وراح نعمل عليه! 👇",
                    parse_mode="Markdown",
                    reply_markup={"inline_keyboard": [
                        [{"text": "📩 طلب دعم المتجر", "callback_data": "request_store_support"}],
                        [{"text": "⬅️ رجوع للقائمة", "callback_data": "back_to_menu"}],
                    ]},
                )
            return

        # ── رابط منتج ──
        url_match = re.search(r"https?://\S+", text)
        if url_match:
            url = url_match.group()

            # تنظيف الرابط من tracking parameters
            url = clean_tracking_url(url)

            # التحقق من الباقة
            user_data = get_user(u.id)
            if not user_data or not user_data.get("plan"):
                await update.message.reply_text(
                    "⚠️ ليس لديك باقة.\n\nاختر باقة أولاً:",
                    reply_markup=build_main_menu_keyboard(),
                )
                return

            if user_data.get("expires_at"):
                expiry = datetime.fromisoformat(user_data["expires_at"])
                if expiry < datetime.now():
                    await update.message.reply_text(
                        "⚠️ باقتك منتهية.\n\nجدّد باقتك:",
                        reply_markup=build_main_menu_keyboard(),
                    )
                    return

            store_name = detect_store_name(url)
            await update.message.reply_text(f"🔍 جاري جلب المنتج من {store_name}...")

            product_info = await fetch_price(url)
            if not product_info:
                await update.message.reply_text(
                    f"⚠️ ما قدرت أجلب السعر.\n\n"
                    "الأسباب المحتملة:\n"
                    "• الرابط غير صحيح أو المنتج غير متوفر\n"
                    "• المتجر يحتاج تسجيل دخول\n"
                    "• المتجر يحجب الطلبات الآلية\n\n"
                    "💡 جرّب أرسل رابط مباشر لصفحة المنتج."
                )
                return

            user_states[u.id] = {
                "state": "choosing_alert",
                "url": url,
                "product_info": product_info,
            }

            cur = product_info.get("currency", "ر.س")
            await update.message.reply_text(
                f"📦 *{product_info['title'][:60]}*\n"
                f"💰 السعر: {product_info['price']} {cur}\n"
                f"🏪 {product_info['store']}\n\n"
                f"كيف تبغى التنبيه؟",
                parse_mode="Markdown",
                reply_markup={"inline_keyboard": [
                    [{"text": "🔔 نبّهني لما ينزل أي مبلغ", "callback_data": "alert_any"}],
                    [{"text": "🎯 نبّهني لما يوصل سعر معيّن", "callback_data": "alert_target"}],
                ]},
            )
            return

        # رسالة عادية
        await update.message.reply_text(
            "أرسل رابط المنتج اللي تبغى تتبّعه 🔗\nأو /help للمساعدة."
        )

    # ─── فحص دوري ─────────────────────────────────────
    async def price_check_free_job(context):
        await check_prices_free(context.bot)

    async def price_check_scraperapi_job(context):
        await check_prices_scraperapi(context.bot)

    # ─── القائمة السفلية ──────────────────────────────
    async def post_init(application):
        await application.bot.set_my_commands([
            BotCommand("start", "ابدأ واختر باقتك"),
            BotCommand("list", "عرض منتجاتك المراقبة"),
            BotCommand("plan", "عرض باقتك الحالية"),
            BotCommand("remove", "حذف منتج من المراقبة"),
            BotCommand("report", "بلّغ عن مشكلة"),
            BotCommand("terms", "سياسة الاستخدام"),
            BotCommand("help", "المساعدة"),
        ])

    app.post_init = post_init

    # ─── التسجيل ──────────────────────────────────────
    app.add_handler(CommandHandler("start", cmd_start))
    app.add_handler(CommandHandler("list", cmd_list))
    app.add_handler(CommandHandler("plan", cmd_plan))
    app.add_handler(CommandHandler("remove", cmd_remove))
    app.add_handler(CommandHandler("report", cmd_report))
    app.add_handler(CommandHandler("help", cmd_help))
    app.add_handler(CommandHandler("terms", cmd_terms))
    app.add_handler(CommandHandler("stats", cmd_stats))
    app.add_handler(CommandHandler("users", cmd_users))
    app.add_handler(CommandHandler("reply", cmd_reply))

    app.add_handler(CallbackQueryHandler(handle_callback))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, handle_message))

    # متاجر مجانية: كل ساعة (3600 ثانية)
    app.job_queue.run_repeating(price_check_free_job, interval=3600, first=60)
    # متاجر ScraperAPI: كل يوم (86400 ثانية)
    app.job_queue.run_repeating(price_check_scraperapi_job, interval=86400, first=300)

    logging.info("🚀 نبّهني بوت شغّال!")
    app.run_polling(drop_pending_updates=True)

if __name__ == "__main__":
    main()

async def _convert_to_sar(result: dict) -> dict:
    """تحويل السعر للريال السعودي إذا كان بعملة أخرى"""
    cur = result.get("currency", "ر.س")
    if cur == "ر.س":
        return result

    # أسعار الصرف الثابتة (احتياطية)
    fallback_rates = {
        "€": 3.95, "$": 3.75, "د.إ": 1.02,
        "EUR": 3.95, "USD": 3.75, "AED": 1.02, "GBP": 4.70,
        "KWD": 12.20, "BHD": 9.95, "QAR": 1.03, "OMR": 9.75,
    }

    rate = fallback_rates.get(cur)
    if not rate:
        return result

    # نحاول نجيب سعر اليوم من API مجاني
    try:
        import aiohttp
        cur_code = cur
        if cur == "€":
            cur_code = "EUR"
        elif cur == "$":
            cur_code = "USD"
        elif cur == "د.إ":
            cur_code = "AED"

        async with aiohttp.ClientSession() as session:
            async with session.get(
                f"https://open.er-api.com/v6/latest/{cur_code}",
                timeout=aiohttp.ClientTimeout(total=5), ssl=False,
            ) as resp:
                if resp.status == 200:
                    data = await resp.json()
                    if data.get("result") == "success" and "SAR" in data.get("rates", {}):
                        rate = data["rates"]["SAR"]
    except Exception:
        pass  # نستخدم السعر الاحتياطي

    original_price = result["price"]
    converted = round(original_price * rate, 2)
    logging.info(f"Currency convert: {original_price} {cur} → {converted} ر.س (rate: {rate})")
    result["price"] = converted
    result["currency"] = "ر.س"
    return result

async def fetch_price(url: str, is_periodic: bool = False) -> Optional[dict]:
    """
    جلب السعر — يدعم أي متجر
    الترتيب الموحّد لكل المتاجر:
    1. aiohttp مباشر (مجاني)
    2. IPRoyal proxy (مجاني)
    3. Playwright متصفح حقيقي (مجاني، ما عدا أمازون)
    4. ScraperAPI (مدفوع — 5000 طلب/شهر)
    5. Google Search (ملاذ أخير)

    استثناء نون: يجرب API الداخلي قبل كل شي
    is_periodic: إذا True = فحص دوري (نسجّل هل استخدم ScraperAPI)
    """
    import aiohttp, asyncio
    from bs4 import BeautifulSoup

    store_name = detect_store_name(url)
    url = await _expand_short_url(url)
    store_name = detect_store_name(url)

    # ── نون: نجرب API الداخلي أولاً (مجاني وأسرع) ──
    if "noon.com" in url.lower():
        result = await fetch_price_noon_api(url)
        if result:
            return result
        logging.info("Noon API failed, trying normal methods...")

    # ── الخطوة 1: aiohttp مباشر (مجاني) ──
    result = await _fetch_price_aiohttp(url, store_name)

    # ── الخطوة 2: IPRoyal proxy (مجاني) ──
    if not result:
        result = await _fetch_price_proxy(url, store_name)

    # ── الخطوة 3: Playwright (مجاني، ما عدا أمازون) ──
    if not result and "amazon." not in url:
        result = await _fetch_price_playwright(url, store_name)

    # ── الخطوة 4: ScraperAPI مع retry (مدفوع) ──
    if not result:
        for attempt in range(2):
            result = await _fetch_price_scraperapi(url, store_name)
            if result:
                result["_used_scraperapi"] = True
                break
            if attempt == 0:
                logging.info(f"ScraperAPI attempt 1 failed, retrying in 3s...")
                await asyncio.sleep(3)

    # ── الخطوة 5: Google Search (ملاذ أخير) ──
    if not result:
        logging.info(f"Trying Google for: {url[:50]}")
        result = await _fetch_price_google(url, store_name)
        if result:
            result["_used_scraperapi"] = True

    # ── تحويل العملة للريال السعودي إذا كانت عملة أخرى ──
    if result:
        result = await _convert_to_sar(result)

    return result

def _extract_price_from_jsonld(soup_or_html, is_html=False) -> Optional[dict]:
    """استخراج السعر من JSON-LD — يرجّع أقل سعر بيع"""
    from bs4 import BeautifulSoup

    if is_html:
        soup = BeautifulSoup(soup_or_html, "html.parser")
    else:
        soup = soup_or_html

    best = None  # {"title", "price", "currency"}

    for script in soup.find_all("script", {"type": "application/ld+json"}):
        try:
            raw = script.string or ""
            data = json.loads(raw)

            # أحيانًا مصفوفة
            items = data if isinstance(data, list) else [data]

            for item in items:
                if not isinstance(item, dict):
                    continue

                # البحث في @graph
                if "@graph" in item:
                    items.extend(item["@graph"])
                    continue

                title = item.get("name", "")

                # جمع كل الأسعار الممكنة
                all_offers = []

                offers_raw = item.get("offers", item.get("Offers", {}))
                if isinstance(offers_raw, dict):
                    if "offers" in offers_raw:
                        # AggregateOffer
                        inner = offers_raw["offers"]
                        if isinstance(inner, list):
                            all_offers.extend(inner)
                        elif isinstance(inner, dict):
                            all_offers.append(inner)
                    else:
                        all_offers.append(offers_raw)
                elif isinstance(offers_raw, list):
                    all_offers.extend(offers_raw)

                # إضافة السعر من المستوى الأعلى
                if item.get("price"):
                    all_offers.append(item)

                for offer in all_offers:
                    if not isinstance(offer, dict):
                        continue

                    # الأولوية: سعر البيع > السعر العادي
                    for price_key in ["sale_price", "salePrice", "lowPrice", "price", "highPrice"]:
                        val = offer.get(price_key)
                        if val is not None:
                            try:
                                p = float(str(val).replace(",", "").replace("٬", ""))
                                if p > 0:
                                    cur_raw = offer.get("priceCurrency", item.get("priceCurrency", "SAR"))
                                    cur = "ر.س"
                                    if str(cur_raw).upper() == "AED":
                                        cur = "د.إ"
                                    elif str(cur_raw).upper() == "USD":
                                        cur = "$"
                                    elif str(cur_raw).upper() == "EUR":
                                        cur = "€"

                                    if best is None or p < best["price"]:
                                        best = {"title": title or "", "price": p, "currency": cur}
                                    break  # وجدنا سعر لهذا الـ offer
                            except (ValueError, TypeError):
                                continue

        except Exception:
            continue

    return best

def _extract_price_from_meta(soup) -> Optional[float]:
    """استخراج السعر من meta tags"""
    for attr in ["product:price:amount", "og:price:amount"]:
        el = soup.find("meta", {"property": attr}) or soup.find("meta", {"name": attr})
        if el and el.get("content"):
            try:
                pt = re.sub(r"[^\d.]", "", el["content"].replace(",", ""))
                if pt:
                    p = float(pt)
                    if p > 0:
                        return p
            except ValueError:
                continue
    return None

def _extract_amazon_price(soup) -> Optional[float]:
    """استخراج السعر الرئيسي من أمازون فقط"""
    # 1) السعر من corePrice div (الأدق)
    core = soup.find(id="corePrice_feature_div")
    if core:
        el = core.find(class_="a-offscreen")
        if el:
            text = el.get_text(strip=True)
            m = re.search(r'([\d,.]+)', text.replace(',', ''))
            if m:
                p = float(m.group(1))
                if p > 0:
                    return p
    # 2) priceblock
    for pid in ["priceblock_ourprice", "priceblock_dealprice", "priceblock_saleprice"]:
        el = soup.find(id=pid)
        if el:
            m = re.search(r'([\d,.]+)', el.get_text().replace(',', ''))
            if m:
                p = float(m.group(1))
                if p > 0:
                    return p
    # 3) apex price
    apex = soup.find(id="apex_offerDisplay_desktop")
    if apex:
        el = apex.find(class_="a-offscreen")
        if el:
            m = re.search(r'([\d,.]+)', el.get_text().replace(',', ''))
            if m:
                p = float(m.group(1))
                if p > 0:
                    return p
    return None


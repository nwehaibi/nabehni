            if result.get("_used_scraperapi"):
                conn.execute("UPDATE products SET fetch_method = 'scraperapi' WHERE id = ?", (prod["id"],))
                logging.info(f"📌 منتج {prod['id']} تحوّل لـ scraperapi")

            checked += 1
            await _process_price_update(conn, bot, prod["user_id"], prod, result)

        except Exception as e:
            logging.error(f"Check error (free): {e}")

    conn.commit()
    conn.close()
    logging.info(f"✅ فحص المجانية انتهى — {checked} منتج")

async def check_prices_scraperapi(bot):
    """فحص المنتجات اللي تحتاج ScraperAPI — كل يوم"""
    logging.info("⏰ فحص دوري — منتجات ScraperAPI")
    conn = get_db()
    now = datetime.now().isoformat()

    products = conn.execute("""
        SELECT p.*, u.user_id FROM products p
        JOIN users u ON p.user_id = u.user_id
        WHERE u.expires_at > ? AND p.fetch_method = 'scraperapi'
    """, (now,)).fetchall()

    checked = 0
    for prod in products:
        prod = dict(prod)
        try:
            result = await fetch_price(prod["url"], is_periodic=True)
            if not result:
                continue

            # لو المنتج نجح مجاناً هالمرة، نرجّعه للفحص كل ساعة
            if not result.get("_used_scraperapi"):
                conn.execute("UPDATE products SET fetch_method = 'free' WHERE id = ?", (prod["id"],))
                logging.info(f"📌 منتج {prod['id']} رجع مجاني")

            checked += 1
            await _process_price_update(conn, bot, prod["user_id"], prod, result)

        except Exception as e:
            logging.error(f"Check error (scraperapi): {e}")

    conn.commit()
    conn.close()
    logging.info(f"✅ فحص ScraperAPI انتهى — {checked} منتج")

async def _process_price_update(conn, bot, uid, prod, result):
    """معالجة تحديث السعر وإرسال التنبيه"""
    new_price = result["price"]
    old_price = prod["current_price"]

    # تحديث
    new_lowest = min(prod.get("lowest_price") or float("inf"), new_price)
    conn.execute("""
        UPDATE products SET current_price = ?, lowest_price = ?, last_checked = ?
        WHERE id = ?
    """, (new_price, new_lowest, datetime.now().isoformat(), prod["id"]))

    if new_price != old_price:
        conn.execute("""
            INSERT INTO price_history (product_id, price) VALUES (?, ?)
        """, (prod["id"], new_price))

    # التنبيه
    should_alert = False
    if prod.get("target_price"):
        if new_price <= prod["target_price"] and new_price < old_price:
            should_alert = True
    else:
        if new_price < old_price:
            should_alert = True

    if should_alert:
        drop = old_price - new_price
        cur = prod.get("currency", "ر.س")
        msg = (
            f"🔔 *تنبيه نزول سعر!*\n\n"
            f"📦 {prod['title'][:60]}\n"
            f"💰 السعر القديم: {old_price} {cur}\n"
            f"🔥 السعر الجديد: {new_price} {cur}\n"
            f"📉 وفّرت: {drop:.0f} {cur}\n"
            f"📊 أقل سعر مسجّل: {new_lowest} {cur}\n\n"
            f"🔗 [اشترِ الآن]({prod['url']})"
        )
        try:
            await bot.send_message(
                chat_id=uid, text=msg,
                parse_mode="Markdown",
                disable_web_page_preview=True,
            )
        except Exception as e:
            logging.error(f"Alert error to {uid}: {e}")


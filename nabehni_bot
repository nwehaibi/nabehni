def get_admin_stats() -> str:
    conn = get_db()
    now = datetime.now().isoformat()

    total_users = conn.execute("SELECT COUNT(*) FROM users").fetchone()[0]
    active_free = conn.execute(
        "SELECT COUNT(*) FROM users WHERE plan = 'free' AND expires_at > ?", (now,)
    ).fetchone()[0]
    active_basic = conn.execute(
        "SELECT COUNT(*) FROM users WHERE plan = 'basic' AND expires_at > ?", (now,)
    ).fetchone()[0]
    active_pro = conn.execute(
        "SELECT COUNT(*) FROM users WHERE plan = 'pro' AND expires_at > ?", (now,)
    ).fetchone()[0]

    total_products = conn.execute("SELECT COUNT(*) FROM products").fetchone()[0]
    pending_orders = conn.execute(
        "SELECT COUNT(*) FROM orders WHERE status = 'pending'"
    ).fetchone()[0]

    # كم واحد جرّب المجانية ثم اشترك مدفوع
    free_then_paid = conn.execute("""
        SELECT COUNT(*) FROM users
        WHERE used_free_trial = 1 AND plan IN ('basic', 'pro')
    """).fetchone()[0]

    total_free_tried = conn.execute(
        "SELECT COUNT(*) FROM users WHERE used_free_trial = 1"
    ).fetchone()[0]

    total_reports = conn.execute("SELECT COUNT(*) FROM reports").fetchone()[0]

    conn.close()

    active_total = active_free + active_basic + active_pro
    conversion = f"{(free_then_paid/total_free_tried*100):.0f}%" if total_free_tried > 0 else "0%"

    return (
        f"📊 *إحصائيات نبّهني*\n\n"
        f"👥 إجمالي المستخدمين: {total_users}\n"
        f"✅ المشتركين الفعّالين: {active_total}\n"
        f"   ├ 🆓 مجانية: {active_free}\n"
        f"   ├ ⭐ أساسية: {active_basic}\n"
        f"   └ 💎 برو: {active_pro}\n\n"
        f"📦 المنتجات المتتبعة: {total_products}\n"
        f"⏳ طلبات معلّقة: {pending_orders}\n"
        f"📬 البلاغات: {total_reports}\n\n"
        f"📈 *معدل التحويل:*\n"
        f"جرّبوا المجانية: {total_free_tried}\n"
        f"اشتركوا مدفوع: {free_then_paid}\n"
        f"النسبة: {conversion}"
    )

def get_admin_users_detail() -> str:
    """تفاصيل المستخدمين للأدمن"""
    conn = get_db()
    rows = conn.execute("""
    SELECT u.*, COUNT(p.id) as product_count
    FROM users u
    LEFT JOIN products p ON u.user_id = p.user_id
    GROUP BY u.user_id
    ORDER BY u.joined_at DESC
    LIMIT 50
    """).fetchall()
    conn.close()

    if not rows:
        return "📭 لا يوجد مستخدمين."

    text = "👥 *آخر ٥٠ مستخدم:*\n\n"
    for r in rows:
        r = dict(r)
        plan_icon = {"free": "🆓", "basic": "⭐", "pro": "💎"}.get(r["plan"] or "", "❌")
        name = r.get("first_name") or r.get("username") or "بدون اسم"
        text += (
            f"{plan_icon} *{name}* (`{r['user_id']}`)\n"
            f"   الباقة: {r.get('plan_name') or 'بدون'} | "
            f"المنتجات: {r['product_count']}\n"
        )
        if r.get("expires_at"):
            exp = datetime.fromisoformat(r["expires_at"])
            remaining = max(0, (exp - datetime.now()).days)
            text += f"   متبقي: {remaining} يوم\n"
        text += "\n"

    return text


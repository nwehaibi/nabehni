# ─── إعدادات أساسية (مطلوبة) ───────────────────────
# توكن البوت من @BotFather
BOT_TOKEN=هنا_حط_التوكن_من_BotFather

# رقم حسابك في تيليجرام (تحصله من @userinfobot)
ADMIN_ID=هنا_حط_رقم_حسابك

# ─── إعدادات سلة (مطلوبة للدفع) ─────────────────────
# رابط متجرك في سلة
SALLA_STORE_URL=https://your-store.salla.sa

# روابط المنتجات (الباقات) في سلة
SALLA_BASIC_URL=https://your-store.salla.sa/product/basic
SALLA_PRO_URL=https://your-store.salla.sa/product/pro

# ─── إعدادات اختيارية (للمتاجر المحمية) ─────────────
# مفتاح ScraperAPI (سجل مجاني في scraperapi.com)
SCRAPER_API_KEY=

# بروكسي IPRoyal (اختياري - للمتاجر اللي تحجب)
IPROYAL_PROXY=
IPROYAL_PROXY_SERVER=
IPROYAL_PROXY_USER=
IPROYAL_PROXY_PASS=
